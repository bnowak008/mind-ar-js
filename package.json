{
  "name": "mind-ar",
  "version": "1.2.5",
  "description": "web augmented reality framework",
  "main": "index.js",
  "scripts": {
    "dev": "bun run dev.ts",
    "dev:build": "bun run build.ts dev && bun run --bun serve examples --port 2020 --hot",
    "dev:watch": "bun run build.ts dev --watch",
    "serve": "bun run --bun serve examples --port 2020 --hot",
    "watch": "bun run build.ts dev --watch",
    "build-dev": "bun run build.ts dev && bun run build.ts aframe",
    "build": "bun run build.ts prod",
    "build:es": "bun run build.ts dev",
    "build:aframe-image": "bun run build.ts aframe-image",
    "build:aframe-face": "bun run build.ts aframe-face",
    "build:aframe": "bun run build.ts aframe",
    "typecheck": "bun run --bun tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "clean": "rm -rf dist dist-dev node_modules packages/*/node_modules apps/*/node_modules",
    "install:workspaces": "bun install",
    "lint": "bun run --bun tsc --noEmit",
    "benchmark": "bun run benchmark.ts",
    "benchmark:build": "bun run build.ts prod && echo 'Build benchmark completed'"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/hiukim/mind-ar-js"
  },
  "keywords": [
    "web AR",
    "aframe",
    "web augmented reality",
    "image tracking",
    "face tracking",
    "tensorflowjs",
    "mediapipe"
  ],
  "author": "hiukim",
  "license": "MIT",
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.21",
    "@msgpack/msgpack": "^3.1.2",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "mathjs": "^14.8.1",
    "ml-matrix": "^6.12.1",
    "svd-js": "^1.1.1",
    "tinyqueue": "^3.0.0",
    "@techstark/opencv-js": "^4.11.0-release.1"
  },
  "peerDependencies": {
    "three": ">=0.136.0"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "devDependencies": {
    "@types/three": "^0.160.0",
    "typescript": "^5.7.2"
  }
}
